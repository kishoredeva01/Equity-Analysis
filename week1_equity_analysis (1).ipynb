        "---\n",
        "## 📌 Section 1 — Define Your Stock Universe\n",
        "\n",
        "> **How to customise:** Change the tickers in `STOCKS` to any NSE-listed stocks.  \n",
        "> NSE tickers on yfinance always end with `.NS` (e.g., `RELIANCE.NS`, `HDFCBANK.NS`)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 3,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "9z914i_Y8S1R",
        "outputId": "8581e516-cb46-48cd-cc86-c2f3bf73fda5"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Stock universe: ['HDFC Bank', 'Reliance', 'Infosys', 'TCS', 'ICICI Bank']\n",
            "Period: 1y | Benchmark: Nifty 50\n"
          ]
        }
      ],
      "source": [
        "# ── CONFIGURE YOUR UNIVERSE HERE ──────────────────────────────────────────────\n",
        "\n",
        "STOCKS = {\n",
        "    'HDFC Bank':    'HDFCBANK.NS',\n",
        "    'Reliance':     'RELIANCE.NS',\n",
        "    'Infosys':      'INFY.NS',\n",
        "    'TCS':          'TCS.NS',\n",
        "    'ICICI Bank':   'ICICIBANK.NS'\n",
        "}\n",
        "\n",
        "PERIOD = '1y'          # Options: 6mo, 1y, 2y, 5y\n",
        "BENCHMARK = '^NSEI'    # Nifty 50 index\n",
        "TRADING_DAYS = 252     # Standard assumption for annualisation\n",
        "\n",
        "# ──────────────────────────────────────────────────────────────────────────────\n",
        "\n",
        "tickers = list(STOCKS.values())\n",
        "names   = list(STOCKS.keys())\n",
        "colors  = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd']\n",
        "\n",
        "print(f'Stock universe: {names}')\n",
        "print(f'Period: {PERIOD} | Benchmark: Nifty 50')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "oh3THSTE8S1R"
      },
      "source": [
        "---\n",
        "## 📥 Section 2 — Download Price Data"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 4,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "r7M2vQRG8S1S",
        "outputId": "8fd1fd5a-f7e0-4ba0-86a3-cc5bc723b307"
