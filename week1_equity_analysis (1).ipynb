        "---\n",
        "## 🔢 Section 5 — Daily Returns Calculation\n",
        "\n",
        "> **Formula:** Daily Return = (Today's Price − Yesterday's Price) / Yesterday's Price  \n",
        "> In pandas: `pct_change()` does this automatically."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "aGWiKfhi8S1T",
        "outputId": "1931e973-756a-49f8-d01e-2ed4b2eaafb1"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Daily Returns — Descriptive Statistics:\n",
            "=======================================================\n",
            "            Count     Mean Std Dev      Min      25%   Median     75%     Max\n",
            "HDFC Bank     249  -0.075%  1.177%  -5.320%  -0.668%  -0.036%  0.558%  5.712%\n",
            "Reliance      249   0.017%  1.267%  -4.600%  -0.766%   0.000%  0.693%  4.306%\n",
            "Infosys       249  -0.076%  1.649%  -7.258%  -1.016%  -0.058%  0.719%  7.913%\n",
            "TCS           249  -0.119%  1.405%  -7.013%  -0.828%  -0.094%  0.695%  5.235%\n",
            "ICICI Bank    249  -0.042%  1.162%  -3.256%  -0.691%  -0.092%  0.534%  5.114%\n"
          ]
        }
      ],
      "source": [
        "# Daily returns\n",
        "daily_returns = close_prices.pct_change().dropna()\n",
        "\n",
        "print('Daily Returns — Descriptive Statistics:')\n",
        "print('=' * 55)\n",
        "summary = daily_returns.describe().T\n",
        "summary.columns = ['Count', 'Mean', 'Std Dev', 'Min', '25%', 'Median', '75%', 'Max']\n",
        "\n",
        "# Format as percentages\n",
        "pct_cols = ['Mean', 'Std Dev', 'Min', '25%', 'Median', '75%', 'Max']\n",
        "display_summary = summary.copy()\n",
        "for col in pct_cols:\n",
        "    display_summary[col] = display_summary[col].apply(lambda x: f'{x*100:.3f}%')\n",
        "display_summary['Count'] = display_summary['Count'].astype(int)\n",
        "\n",
        "print(display_summary.to_string())"
      ]
    },
