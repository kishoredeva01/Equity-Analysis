            "Name: 2026-05-06 00:00:00, dtype: object\n"
          ]
        }
      ],
      "source": [
        "print('Downloading stock data from Yahoo Finance...')\n",
        "\n",
        "raw = yf.download(tickers + [BENCHMARK], period=PERIOD, auto_adjust=True, progress=False)\n",
        "\n",
        "# Extract closing prices and rename columns to friendly names\n",
        "close_prices = raw['Close'][tickers].copy()\n",
        "close_prices.columns = names\n",
        "\n",
        "# Volume data\n",
        "volume = raw['Volume'][tickers].copy()\n",
        "volume.columns = names\n",
        "\n",
        "# Benchmark (Nifty)\n",
        "nifty = raw['Close'][BENCHMARK].copy()\n",
        "\n",
        "# Drop rows where ALL stocks have NaN\n",
        "close_prices.dropna(how='all', inplace=True)\n",
        "nifty.dropna(inplace=True)\n",
        "\n",
        "print(f'✅ Data downloaded: {len(close_prices)} trading days')\n",
        "print(f'   From: {close_prices.index[0].date()}  →  To: {close_prices.index[-1].date()}')\n",
        "print()\n",
        "print('Latest closing prices (₹):')\n",
        "print(close_prices.iloc[-1].apply(lambda x: f'₹{x:,.2f}'))"
      ]
    },
