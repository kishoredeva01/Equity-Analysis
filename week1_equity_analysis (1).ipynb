      "source": [
        "fig, ax = plt.subplots(figsize=(13, 5))\n",
        "\n",
        "for i, stock in enumerate(names):\n",
        "    ax.plot(rolling_vol.index, rolling_vol[stock], label=stock,\n",
        "            color=colors[i], linewidth=1.6, alpha=0.85)\n",
        "\n",
