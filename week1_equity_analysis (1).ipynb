      "source": [
        "# ── Build comprehensive summary table ─────────────────────────────────────────\n",
        "\n",
        "summary_data = {}\n",
        "\n",
        "for stock in names:\n",
        "    ticker_sym = STOCKS[stock]\n",
        "    prices = close_prices[stock].dropna()\n",
        "    rets   = daily_returns[stock].dropna()\n",
        "\n",
        "    start_price  = prices.iloc[0]\n",
        "    end_price    = prices.iloc[-1]\n",
        "    total_return = (end_price / start_price - 1) * 100\n",
        "\n",
        "    ann_vol_pct  = rets.std() * np.sqrt(TRADING_DAYS) * 100\n",
        "    ann_ret_pct  = rets.mean() * TRADING_DAYS * 100\n",
        "    sharpe       = (ann_ret_pct / ann_vol_pct) if ann_vol_pct != 0 else 0\n",
        "\n",
        "    max_price    = prices.max()\n",
        "    min_price    = prices.min()\n",
        "    drawdown     = (end_price / max_price - 1) * 100\n",
        "\n",
        "    best_day     = rets.max() * 100\n",
        "    worst_day    = rets.min() * 100\n",
        "    pos_days_pct = (rets > 0).sum() / len(rets) * 100\n",
        "\n",
        "    summary_data[stock] = {\n",
        "        'Start Price (₹)':      f'{start_price:,.1f}',\n",
        "        'End Price (₹)':        f'{end_price:,.1f}',\n",
        "        '1Y Total Return':      f'{total_return:+.1f}%',\n",
        "        'Ann. Volatility':      f'{ann_vol_pct:.1f}%',\n",
        "        'Sharpe Ratio*':        f'{sharpe:.2f}',\n",
        "        'Best Day':             f'{best_day:+.2f}%',\n",
        "        'Worst Day':            f'{worst_day:+.2f}%',\n",
        "        '% Positive Days':      f'{pos_days_pct:.0f}%',\n",
        "        'Drawdown from Peak':   f'{drawdown:.1f}%',\n",
        "    }\n",
        "\n",
        "summary_df = pd.DataFrame(summary_data)\n",
        "\n",
        "print('='*65)\n",
        "print('      EQUITY ANALYSIS SUMMARY — 5 NIFTY STOCKS')\n",
        "print('='*65)\n",
        "print(summary_df.to_string())\n",
        "print('='*65)\n",
        "print('* Sharpe Ratio uses annualised return / annualised volatility')\n",
        "print('  (risk-free rate assumed 0 for simplicity — adjust as needed)')\n",
        "print()"
      ]
    },
