        "---\n",
        "## 💹 Section 6 — Cumulative Returns"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 624
        },
        "id": "rufKFW5i8S1U",
        "outputId": "7ce7dbcd-4d75-48d6-8c89-c48391050956"
      },
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1560x600 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ],
      "source": [
        "# Cumulative returns: how ₹1 invested grew over the period\n",
        "cumulative_returns = (1 + daily_returns).cumprod()\n",
        "nifty_daily = nifty.pct_change().dropna()\n",
        "nifty_cumulative = (1 + nifty_daily).cumprod()\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(13, 5))\n",
        "\n",
        "for i, stock in enumerate(names):\n",
        "    final_val = cumulative_returns[stock].iloc[-1]\n",
        "    ax.plot(cumulative_returns.index, cumulative_returns[stock],\n",
        "            label=f'{stock} ({(final_val-1)*100:+.1f}%)',\n",
        "            color=colors[i], linewidth=1.8)\n",
        "\n",
        "nifty_final = nifty_cumulative.iloc[-1]\n",
        "ax.plot(nifty_cumulative.index, nifty_cumulative,\n",
        "        label=f'Nifty 50 ({(nifty_final-1)*100:+.1f}%)',\n",
        "        color='black', linewidth=1.5, linestyle='--', alpha=0.7)\n",
        "\n",
        "ax.axhline(1.0, color='gray', linewidth=0.8, linestyle=':')\n",
        "ax.set_title('Cumulative Returns — ₹1 Invested 1 Year Ago', fontsize=14, fontweight='bold', pad=12)\n",
        "ax.set_ylabel('Value of ₹1 Invested', fontsize=11)\n",
        "ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'₹{x:.2f}'))\n",
        "ax.legend(frameon=False, fontsize=10)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('cumulative_returns.png', bbox_inches='tight')\n",
        "plt.show()"
      ]
    },
    {
